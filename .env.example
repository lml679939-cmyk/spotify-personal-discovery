# ── 本地開發用設定 ──
# 從 https://developer.spotify.com/dashboard 建立 App 後取得
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# 本地跑 Streamlit 預設 port 8501；雲端部署改成 https://你的app.streamlit.app/
# ⚠️ 這個值必須跟 Spotify Developer Dashboard 的 Redirect URIs 一字不差
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8501/

# 從 https://aistudio.google.com/app/apikey 取得
GEMINI_API_KEY=your_gemini_key_here
